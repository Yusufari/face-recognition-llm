import tensorflow as tf
from tensorflow import keras
import numpy as np
import matplotlib.pyplot as plt

print("=" * 60)
print("DAY 7 - VERSION C")
print("8 Juni 2026")
print("CNN with Layer Visualization")
print("=" * 60)

# 1. LOAD DATA
print("\n--- LOADING DIGIT DATASET ---")
mnist = keras.datasets.mnist
(x_train, y_train), (x_test, y_test) = mnist.load_data()

# Use smaller dataset for faster training
x_train = x_train[:5000] / 255.0
y_train = y_train[:5000]
x_test = x_test[:1000] / 255.0
y_test = y_test[:1000]

print(f"Training: {len(x_train)} images")
print(f"Testing: {len(x_test)} images")

# 2. BUILD SIMPLE MODEL
print("\n--- BUILDING MODEL ---")
model = keras.Sequential([
    keras.layers.Flatten(input_shape=(28, 28)),
    keras.layers.Dense(64, activation='relu'),
    keras.layers.Dense(10, activation='softmax')
])

model.compile(
    optimizer='adam',
    loss='sparse_categorical_crossentropy',
    metrics=['accuracy']
)

model.summary()

# 3. TRAIN
print("\n--- TRAINING ---")
history = model.fit(
    x_train, y_train,
    epochs=10,
    validation_data=(x_test, y_test),
    verbose=0
)

# 4. RESULTS
print("\n--- RESULTS ---")
test_loss, test_acc = model.evaluate(x_test, y_test, verbose=0)
print(f"Test Accuracy: {test_acc:.4f} ({test_acc*100:.1f}%)")

# 5. SHOW TRAINING PROGRESS
plt.figure(figsize=(12, 4))

plt.subplot(1, 2, 1)
plt.plot(history.history['accuracy'], label='Train')
plt.plot(history.history['val_accuracy'], label='Test')
plt.title('Accuracy over time')
plt.xlabel('Epoch')
plt.ylabel('Accuracy')
plt.legend()

plt.subplot(1, 2, 2)
plt.plot(history.history['loss'], label='Train')
plt.plot(history.history['val_loss'], label='Test')
plt.title('Loss over time')
plt.xlabel('Epoch')
plt.ylabel('Loss')
plt.legend()

plt.tight_layout()
plt.show()

# 6. SHOW PREDICTIONS
print("\n--- SAMPLE PREDICTIONS ---")

plt.figure(figsize=(12, 3))

for i in range(6):
    plt.subplot(1, 6, i+1)
    plt.imshow(x_test[i], cmap='gray')
    
    pred = np.argmax(model.predict(x_test[i:i+1], verbose=0))
    actual = y_test[i]
    
    color = 'green' if pred == actual else 'red'
    plt.title(f'P:{pred}\nA:{actual}', color=color)
    plt.axis('off')

plt.tight_layout()
plt.show()

# 7. CONFUSION MATRIX
print("\n--- WHERE MODEL MAKES MISTAKES ---")
from sklearn.metrics import confusion_matrix

y_pred = np.argmax(model.predict(x_test, verbose=0), axis=1)
cm = confusion_matrix(y_test, y_pred)

plt.figure(figsize=(8, 6))
plt.imshow(cm, cmap='Blues')
plt.colorbar()
plt.xlabel('Predicted')
plt.ylabel('Actual')
plt.title('Confusion Matrix')
plt.show()

print("\n✅ DAY 7 - VERSION C DONE!")
