# Testing image
plt.subplot(1, 2, 2)
test_display = cv2.cvtColor(cv2.imread(test_image_path), cv2.COLOR_BGR2RGB)
plt.imshow(test_display)

# FIXED: Use boolean flags instead of checking arrays directly
if train_has_face and test_has_face and is_same_person:
    title = "TESTING IMAGE\n(Baymax says: IT'S YOU! ✅)"
elif train_has_face and test_has_face and not is_same_person:
    title = "TESTING IMAGE\n(Baymax says: UNKNOWN PERSON ❌)"
elif not train_has_face:
    title = "TESTING IMAGE\n(No face in training image)"
elif not test_has_face:
    title = "TESTING IMAGE\n(No face detected)"
else:
    title = "TESTING IMAGE\n(Unknown error)"

plt.title(title, fontsize=12)
plt.axis('off')

plt.tight_layout()
plt.show()

