# 2. UPLOAD A FACE IMAGE (Training)
print("\n--- STEP 2: UPLOAD YOUR FACE (Training) ---")
print("This will be used to 'teach' the system what you look like")
uploaded_train = files.upload()

for filename in uploaded_train.keys():
    train_image_path = filename
    print(f"Training image: {filename}")

# 3. UPLOAD ANOTHER IMAGE (Testing)
print("\n--- STEP 3: UPLOAD ANOTHER IMAGE (Testing) ---")
print("This can be another photo of you OR a different person")
uploaded_test = files.upload()

for filename in uploaded_test.keys():
    test_image_path = filename
    print(f"Testing image: {filename}")

# 4. ENCODE THE TRAINING IMAGE
print("\n--- STEP 4: ENCODE TRAINING FACE ---")
train_image = face_recognition.load_image_file(train_image_path)
train_encodings = face_recognition.face_encodings(train_image)

if len(train_encodings) > 0:
    train_encoding = train_encodings[0]
    train_has_face = True
    print(f"✓ Training face encoded! (Found 1 face)")
else:
    train_encoding = None
    train_has_face = False
    print("❌ No face found in training image. Please upload a clear face photo.")

# 5. ENCODE THE TESTING IMAGE
print("\n--- STEP 5: ENCODE TESTING FACE ---")
test_image = face_recognition.load_image_file(test_image_path)
test_encodings = face_recognition.face_encodings(test_image)

if len(test_encodings) > 0:
    test_encoding = test_encodings[0]
    test_has_face = True
    print(f"✓ Testing face encoded! (Found 1 face)")
else:
    test_encoding = None
    test_has_face = False
    print("❌ No face found in testing image.")

# 6. COMPARE FACES
print("\n--- STEP 6: COMPARE FACES ---")

# Initialize variables
is_same_person = False
distance = 999.0

if train_has_face and test_has_face:
    # Calculate distance (smaller = more similar)
    distance = np.linalg.norm(train_encoding - test_encoding)
    
    # Check if faces match
    results = face_recognition.compare_faces([train_encoding], test_encoding)
    is_same_person = results[0]
    
    print(f"\nResults:")
    print(f"  Distance between faces: {distance:.4f}")
    print(f"  Same person: {is_same_person}")
    
    # Threshold explanation
    threshold = 0.6
    if distance < threshold:
        print(f"\n✓ RESULT: SAME PERSON!")
        print(f"  (Distance {distance:.4f} < {threshold})")
        print(f"  ✅ Baymax recognizes you!")
    else:
        print(f"\n✗ RESULT: DIFFERENT PERSON!")
        print(f"  (Distance {distance:.4f} > {threshold})")
        print(f"  ❌ This is not you.")
else:
    print("Cannot compare: missing face encoding from one or both images")

