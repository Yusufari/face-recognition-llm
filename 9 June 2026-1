import cv2
import numpy as np
import matplotlib.pyplot as plt
from google.colab import files

print("=" * 60)
print("DAY 8 - VERSION B")
print("9 Juni 2026")
print("Face Detection Only (No extra library)")
print("=" * 60)

# 1. UPLOAD IMAGE
print("\n--- UPLOAD A FACE IMAGE ---")
uploaded = files.upload()

for filename in uploaded.keys():
    image_path = filename
    print(f"Loaded: {filename}")

# 2. LOAD AND DETECT
img = cv2.imread(image_path)
img_rgb = cv2.cvtColor(img, cv2.COLOR_BGR2RGB)
gray = cv2.cvtColor(img, cv2.COLOR_BGR2GRAY)

# Load face detector (built into OpenCV)
face_cascade = cv2.CascadeClassifier(cv2.data.haarcascades + 'haarcascade_frontalface_default.xml')
faces = face_cascade.detectMultiScale(gray, 1.1, 5)

print(f"\nFound {len(faces)} face(s)")

# 3. DRAW RESULTS
img_result = img_rgb.copy()

for i, (x, y, w, h) in enumerate(faces):
    cv2.rectangle(img_result, (x, y), (x+w, y+h), (0, 255, 0), 3)
    cv2.putText(img_result, f"Face {i+1}", (x, y-10), 
                cv2.FONT_HERSHEY_SIMPLEX, 0.6, (0, 255, 0), 2)

# 4. DISPLAY
plt.figure(figsize=(8, 6))
plt.imshow(img_result)
plt.title(f"Face Detection - {len(faces)} face(s) found")
plt.axis('off')
plt.show()

print("\n" + "=" * 60)
print("✅ DAY 8 - VERSION B DONE!")
print("=" * 60)
