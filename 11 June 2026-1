import cv2
import numpy as np
import matplotlib.pyplot as plt
from google.colab import files

print("=" * 60)
print("DAY 10 - VERSION B")
print("11 June 2026")
print("Face Detection on Uploaded Image")
print("=" * 60)

# 1. UPLOAD
print("\n--- UPLOAD A FACE PHOTO ---")
uploaded = files.upload()

for filename in uploaded.keys():
    img_path = filename
    print(f"Loaded: {filename}")

# 2. PROCESS
img = cv2.imread(img_path)
img_rgb = cv2.cvtColor(img, cv2.COLOR_BGR2RGB)
gray = cv2.cvtColor(img, cv2.COLOR_BGR2GRAY)

face_cascade = cv2.CascadeClassifier(cv2.data.haarcascades + 'haarcascade_frontalface_default.xml')
faces = face_cascade.detectMultiScale(gray, 1.1, 5)

# 3. DRAW
for (x, y, w, h) in faces:
    cv2.rectangle(img_rgb, (x, y), (x+w, y+h), (0, 255, 0), 3)
    cv2.putText(img_rgb, "Face Detected", (x, y-10), cv2.FONT_HERSHEY_SIMPLEX, 0.5, (0, 255, 0), 2)

# 4. SHOW
plt.figure(figsize=(8, 6))
plt.imshow(img_rgb)
plt.title(f"Face Detection Result: {len(faces)} face(s)")
plt.axis('off')
plt.show()

print(f"\n✅ Found {len(faces)} face(s)")

if len(faces) == 0:
    print("\nTips for better detection:")
    print("  - Face should look directly at camera")
    print("  - Good lighting")
    print("  - No sunglasses or mask")

print("\n✅ DAY 10 - VERSION B DONE!")
