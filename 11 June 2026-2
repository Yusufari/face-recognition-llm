import cv2
import numpy as np
import matplotlib.pyplot as plt
from google.colab import files

print("=" * 60)
print("DAY 10 - VERSION C")
print("11 June 2026")
print("Multiple Face Detection")
print("=" * 60)

# 1. UPLOAD
print("\n--- UPLOAD A PHOTO WITH MULTIPLE FACES ---")
uploaded = files.upload()

for filename in uploaded.keys():
    img_path = filename
    print(f"Loaded: {filename}")

# 2. PROCESS
img = cv2.imread(img_path)
img_rgb = cv2.cvtColor(img, cv2.COLOR_BGR2RGB)
gray = cv2.cvtColor(img, cv2.COLOR_BGR2GRAY)

face_cascade = cv2.CascadeClassifier(cv2.data.haarcascades + 'haarcascade_frontalface_default.xml')
faces = face_cascade.detectMultiScale(gray, 1.1, 5)

# 3. DRAW WITH LABELS
colors = [(0, 255, 0), (255, 0, 0), (0, 0, 255), (255, 255, 0), (255, 0, 255)]

for i, (x, y, w, h) in enumerate(faces):
    color = colors[i % len(colors)]
    cv2.rectangle(img_rgb, (x, y), (x+w, y+h), color, 3)
    cv2.putText(img_rgb, f"Person {i+1}", (x, y-10), cv2.FONT_HERSHEY_SIMPLEX, 0.6, color, 2)

# 4. SHOW
plt.figure(figsize=(10, 8))
plt.imshow(img_rgb)
plt.title(f"Found {len(faces)} faces in this photo")
plt.axis('off')
plt.show()

print(f"\n✅ {len(faces)} face(s) detected:")

for i, (x, y, w, h) in enumerate(faces):
    print(f"   Person {i+1}: position ({x}, {y}), size {w}x{h}")

print("\n✅ DAY 10 - VERSION C DONE!")
