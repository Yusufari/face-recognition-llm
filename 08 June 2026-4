plt.subplot(1, 3, 2)
filter_display = np.zeros((3, 3, 3))
filter_display[:, :, 0] = filter_  # Red channel
plt.imshow(filter_display)
plt.title("2. Filter\n(Detects vertical edges)")
plt.axis('off')

plt.subplot(1, 3, 3)
plt.imshow(result, cmap='gray')
plt.title("3. Output\n(Strong response where\ngradient matches)")
plt.axis('off')

plt.tight_layout()
plt.show()

