if len(test_encodings) > 0 and known_encoding is not None:
    test_encoding = test_encodings[0]
    distance = np.linalg.norm(known_encoding - test_encoding)
    
    if distance < 0.6:
        response = f"Baymax: {greeting}, Yusuf! How are you today? I am here to help."
        result_text = "RECOGNIZED - SUCCESS"
        color = (0, 255, 0)
    else:
        response = "Baymax: I do not recognize this person. Please teach me your face."
        result_text = "UNKNOWN PERSON"
        color = (0, 0, 255)
else:
    response = "Baymax: I cannot see a face clearly. Please try another photo."
    result_text = "NO FACE DETECTED"
    color = (255, 0, 0)

# 6. DISPLAY
