# 2. UPLOAD KNOWN FACES
print("\n--- UPLOAD FACES BAYMAX SHOULD KNOW ---")
print("Upload 2-3 photos of people you want to recognize")
uploaded_known = files.upload()

known_encodings = []
known_names = []

for filename in uploaded_known.keys():
    img = face_recognition.load_image_file(filename)
    encodings = face_recognition.face_encodings(img)
    
    if len(encodings) > 0:
        known_encodings.append(encodings[0])
        name = filename.split('.')[0][:10]
        known_names.append(name)
        print(f"✓ Learned: {name}")
    else:
        print(f"❌ No face in: {filename}")

print(f"\nBaymax knows {len(known_encodings)} person(s)")

# 3. UPLOAD TEST IMAGE
print("\n--- UPLOAD TEST IMAGE ---")
print("Upload a photo with faces to recognize")
uploaded_test = files.upload()

for filename in uploaded_test.keys():
    test_path = filename

# 4. PROCESS TEST IMAGE
test_img = face_recognition.load_image_file(test_path)
face_locations = face_recognition.face_locations(test_img)
face_encodings = face_recognition.face_encodings(test_img, face_locations)

print(f"\nFound {len(face_locations)} face(s) in test image")

# 5. DRAW RESULTS
test_display = cv2.cvtColor(test_img, cv2.COLOR_RGB2BGR)

for i, (location, encoding) in enumerate(zip(face_locations, face_encodings)):
    # Compare with known faces
    if len(known_encodings) > 0:
        matches = face_recognition.compare_faces(known_encodings, encoding)
        distances = face_recognition.face_distance(known_encodings, encoding)
        
        if True in matches:
            match_index = np.argmin(distances)
            name = known_names[match_index]
            color = (0, 255, 0)  # Green
        else:
            name = "UNKNOWN"
            color = (0, 0, 255)  # Red
    else:
        name = "UNKNOWN"
        color = (0, 0, 255)
    
    # Draw box
    top, right, bottom, left = location
    cv2.rectangle(test_display, (left, top), (right, bottom), color, 3)
    cv2.putText(test_display, name, (left, top-10), 
                cv2.FONT_HERSHEY_SIMPLEX, 0.6, color, 2)
    
    print(f"  Face {i+1}: {name}")

# 6. DISPLAY
plt.figure(figsize=(10, 8))
plt.imshow(cv2.cvtColor(test_display, cv2.COLOR_BGR2RGB))
plt.title("Face Detection + Recognition Results", fontsize=14)
plt.axis('off')
plt.show()

