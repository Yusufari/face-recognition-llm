if len(test_encodings) > 0 and known_encoding is not None:
    test_encoding = test_encodings[0]
    distance = np.linalg.norm(known_encoding - test_encoding)
    
    if distance < 0.6:
        response = f"🤖 Baymax: {time_greeting}, Yusuf! How are you feeling today?"
        result_text = "WELCOME BACK! ✅"
        color = (0, 255, 0)
    else:
        response = "🤖 Baymax: I don't recognize this person. Please teach me your face."
