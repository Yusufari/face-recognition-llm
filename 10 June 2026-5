# 5. BAYMAX RESPONSES (no emoji)
responses = {
    "happy": "Baymax: You look happy, Yusuf! That is wonderful! Keep smiling!",
    "sad": "Baymax: I see you are feeling sad, Yusuf. I am here for you. Let us talk.",
    "tired": "Baymax: You look tired, Yusuf. Please take a short break and rest.",
    "sick": "Baymax: You do not look well, Yusuf. Please drink water and see a doctor.",
    "stressed": "Baymax: You seem stressed, Yusuf. Take a deep breath. I am here to help."
}

# 6. RECOGNIZE
test_img = face_recognition.load_image_file(test_path)
test_encodings = face_recognition.face_encodings(test_img)

if len(test_encodings) > 0 and known_encoding is not None:
    test_encoding = test_encodings[0]
    distance = np.linalg.norm(known_encoding - test_encoding)
    
    if distance < 0.6:
        response = responses.get(mood, responses["happy"])
        result_text = "RECOGNIZED - SUCCESS"
        color = (0, 255, 0)
    else:
        response = "Baymax: I do not know you. Please teach me your face first."
        result_text = "UNKNOWN PERSON"
        color = (0, 0, 255)
else:
    response = "Baymax: I cannot see a face clearly."
    result_text = "NO FACE DETECTED"
    color = (255, 0, 0)

# 7. DISPLAY
test_display = cv2.cvtColor(test_img, cv2.COLOR_RGB2BGR)
face_locations = face_recognition.face_locations(test_img)

for (top, right, bottom, left) in face_locations:
    cv2.rectangle(test_display, (left, top), (right, bottom), color, 3)

plt.figure(figsize=(10, 8))
plt.imshow(cv2.cvtColor(test_display, cv2.COLOR_BGR2RGB))
plt.title(f"Result: {result_text} | Mood: {mood}", fontsize=14)
